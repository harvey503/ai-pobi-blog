---
// === 首页 ===
// Banner（站点名称+副标题+CTA）+ 精选文章 + 最新文章 + 社交入口

import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { getFeaturedPosts, getAllPosts } from "../lib/content";

// 数据获取
const featuredPosts = await getFeaturedPosts();
const allPosts = await getAllPosts();
const latestPosts = allPosts.slice(0, 6);
---

<BaseLayout title="首页">
  <!-- Banner -->
  <section class="banner-grid relative overflow-hidden py-20 md:py-32 px-4">
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <!-- 站点名称（渐变文字）-->
      <h1 class="text-5xl md:text-7xl font-bold text-gradient mb-6">
        AI破壁猿
      </h1>

      <!-- 副标题 -->
      <p class="text-xl md:text-2xl text-muted mb-8 max-w-2xl mx-auto">
        拆解 AI 技术，分享实战干货。一个技术人的 AI 破壁之旅。
      </p>

      <!-- CTA -->
      <div class="flex justify-center gap-4">
        <a
          href="/blog"
          class="px-8 py-3 rounded-lg bg-brand-500 text-white font-medium hover:bg-brand-600 transition-colors"
        >
          阅读最新文章
        </a>
        <a
          href="/about"
          class="px-8 py-3 rounded-lg border border-brand-500 text-brand-500 font-medium hover:bg-brand-500/10 transition-colors"
        >
          关于我
        </a>
      </div>
    </div>
  </section>

  <!-- 精选文章 -->
  {featuredPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-16">
      <h2 class="text-2xl font-bold mb-8">✨ 精选文章</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredPosts.slice(0, 3).map((post) => <PostCard post={post} />)}
      </div>
    </section>
  )}

  <!-- 最新文章 -->
  <section class="max-w-6xl mx-auto px-4 py-16 bg-gray-50 dark:bg-dark-card/50">
    <h2 class="text-2xl font-bold mb-8">📝 最新文章</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
    {allPosts.length > 6 && (
      <div class="text-center mt-8">
        <a
          href="/blog"
          class="inline-block px-6 py-2 rounded-lg border border-brand-500 text-brand-500 hover:bg-brand-500/10 transition-colors"
        >
          查看全部文章 →
        </a>
      </div>
    )}
  </section>

  <!-- 社交媒体入口 -->
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h2 class="text-2xl font-bold mb-4">📢 关注我的频道</h2>
    <p class="text-muted mb-6">在更多平台找到我，获取 AI 干货内容</p>
    <SocialLinks />
  </section>
</BaseLayout>
