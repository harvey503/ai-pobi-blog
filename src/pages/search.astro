---
// === 搜索页 ===
// 简易客户端搜索（Pagefind 需要在后续集成）
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="搜索">
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-8 text-gradient">🔍 搜索文章</h1>
    <p class="text-muted mb-8">
      搜索功能正在建设中 — 目前支持通过标签和分类浏览文章
    </p>

    <div class="card p-8 text-center">
      <p class="text-lg mb-4">试试从博客页面按标签筛选文章</p>
      <a
        href="/blog"
        class="inline-block px-6 py-3 rounded-lg bg-brand-500 text-white font-medium hover:bg-brand-600 transition-colors"
      >
        浏览所有文章 →
      </a>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .text-muted {
    color: var(--color-muted);
  }
</style>
