---
// === 博客列表页 ===
// 展示所有已发布文章

import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllPosts, getAllTags } from "../../lib/content";

const allPosts = await getAllPosts();
const tags = await getAllTags();
---

<BaseLayout title="博客">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- 页面标题 -->
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">📝 所有文章</h1>
      <p class="text-muted">
        共 {allPosts.length} 篇文章 · 持续更新中
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- 主内容区：文章列表 -->
      <div class="flex-1 min-w-0">
        {allPosts.length > 0 ? (
          <>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {allPosts.map((post) => <PostCard post={post} />)}
            </div>
          </>
        ) : (
          <div class="text-center py-20">
            <p class="text-xl text-muted mb-4">暂无内容，敬请期待</p>
            <p class="text-sm text-muted">
              文章正在创作中，你可以关注公众号获取最新更新
            </p>
          </div>
        )}
      </div>

      <!-- 侧边栏（桌面端） -->
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-24">
          <!-- 标签云 -->
          <div class="p-4 rounded-xl border border-gray-200 dark:border-dark-border">
            <h3 class="font-bold mb-3">🏷️ 标签</h3>
            <div class="flex flex-wrap gap-2">
              {tags.map(({ tag, count }) => (
                <a
                  href={`/blog/tags/${tag}`}
                  class="px-2 py-1 text-sm rounded-full bg-gray-100 dark:bg-dark-card text-muted hover:text-brand-500 transition-colors"
                >
                  {tag} ({count})
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
