---
// === 作品展示页 ===
// 网格卡片展示所有作品，支持类型筛选

import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getProjects } from "../../lib/content";

// 从 URL 查询参数获取筛选类型
const type = Astro.url.searchParams.get("type") || "all";

const projects = await getProjects();
const filteredProjects =
  type === "all" ? projects : projects.filter((p) => p.data.type === type);

const projectTypes = ["all", "个人项目", "商业项目", "开源贡献"];
---

<BaseLayout title="作品">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- 页面标题 -->
    <h1 class="text-3xl md:text-4xl font-bold mb-4">💼 作品集</h1>
    <p class="text-muted mb-8">一些有意思的 side projects 和商业作品</p>

    <!-- 类型筛选 -->
    <div class="flex flex-wrap gap-2 mb-10">
      {projectTypes.map((pt) => (
        <a
          href={pt === "all" ? "/projects" : `/projects?type=${encodeURIComponent(pt)}`}
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
            pt === type
              ? "bg-brand-500 text-white"
              : "bg-gray-100 dark:bg-dark-card text-muted hover:text-brand-500"
          }`}
        >
          {pt === "all" ? "全部" : pt}
        </a>
      ))}
    </div>

    <!-- 作品网格 -->
    {filteredProjects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredProjects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-xl text-muted mb-4">作品正在建设中...</p>
        <p class="text-sm text-muted">
          更多精彩项目即将上线
        </p>
      </div>
    )}
  </div>
</BaseLayout>
