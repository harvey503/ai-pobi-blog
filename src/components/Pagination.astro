---
// === 分页组件 ===
// 上一页 / 页码 / 下一页

export interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
---

<nav class="flex items-center justify-center gap-2" aria-label="分页导航">
  <!-- 上一页 -->
  {currentPage > 1 && (
    <a
      href={currentPage === 2 ? basePath : `${basePath}/page/${currentPage - 1}`}
      class="px-4 py-2 rounded-lg border border-gray-200 dark:border-dark-border text-sm hover:bg-gray-100 dark:hover:bg-dark-card transition-colors"
    >
      ← 上一页
    </a>
  )}

  <!-- 页码 -->
  {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => {
    const isCurrent = page === currentPage;
    const href = page === 1 ? basePath : `${basePath}/page/${page}`;
    return (
      <a
        href={href}
        class={`px-3 py-2 rounded-lg text-sm transition-colors ${
          isCurrent
            ? "bg-brand-500 text-white"
            : "border border-gray-200 dark:border-dark-border hover:bg-gray-100 dark:hover:bg-dark-card"
        }`}
        aria-current={isCurrent ? "page" : undefined}
      >
        {page}
      </a>
    );
  })}

  <!-- 下一页 -->
  {currentPage < totalPages && (
    <a
      href={`${basePath}/page/${currentPage + 1}`}
      class="px-4 py-2 rounded-lg border border-gray-200 dark:border-dark-border text-sm hover:bg-gray-100 dark:hover:bg-dark-card transition-colors"
    >
      下一页 →
    </a>
  )}
</nav>
