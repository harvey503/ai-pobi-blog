---
// === 基础布局组件 ===
// 全站统一布局：<head>（SEO meta、OG、favicon）+ Header + Footer

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config";

export interface Props {
  /** 页面标题（与站点标题拼接） */
  title: string;
  /** 页面描述（用于 SEO meta） */
  description?: string;
  /** OG 图片 URL（默认使用站点默认 OG 图片） */
  image?: string;
  /** Canonical URL（默认使用当前页面 URL） */
  canonicalURL?: string;
  /** 页面类型：website（默认）| article */
  type?: "website" | "article";
  /** 文章发布时间（仅 article 类型需要） */
  publishedTime?: string;
  /** 文章标签（仅 article 类型需要） */
  tags?: string[];
}

const {
  title,
  description = SITE.description,
  image = `${SITE.url}/og-default.png`,
  canonicalURL = Astro.url.href,
  type = "website",
  publishedTime,
  tags,
} = Astro.props;

const siteTitle = `${title} | ${SITE.title}`;

// 处理 OG 图片路径
const ogImage = image.startsWith("http") ? image : `${SITE.url}${image}`;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- 标题 & 描述 -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={SITE.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href="/rss.xml"
    />

    <!-- 全局样式 -->
    <link rel="stylesheet" href="/src/styles/global.css" />

    <!-- 主题切换 FOUC prevention -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        if (
          theme === "dark" ||
          (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <!-- 页面级 head 插槽（用于额外 meta / link 等） -->
    <slot name="head" />
  </head>

  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
